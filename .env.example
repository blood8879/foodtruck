# Supabase sync backend (M2). Copy to .env and fill in.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat 구독 결제 (Android). RevenueCat 대시보드 > Project settings > API keys의
# Google Play용 공개 SDK 키(Public app-specific key)를 넣으세요.
# 비워두면 결제가 비활성화되고 앱은 로컬/데모 모드로 동작합니다(플랜 토글 유지).
# 설정 방법: docs/revenuecat-setup.md
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
